{
  "rules": {
    "//": "SyncWatch Realtime Database rules. Deploy with: firebase deploy --only database",
    "//auth": "Requires Anonymous Auth to be enabled (Firebase Console -> Authentication -> Sign-in method -> Anonymous).",

    ".read": false,
    ".write": false,

    "rooms": {
      "$code": {
        "//": "A room is only accessible to authenticated clients that already know its exact 6-char code. Listing /rooms is denied, so codes cannot be enumerated.",
        ".read": "auth != null && $code.matches(/^[A-Z0-9]{6}$/)",

        "owner": {
          "//": "Claimed once by the Display. A client may only write its own uid, and only if the room is unclaimed or already theirs.",
          ".write": "auth != null && $code.matches(/^[A-Z0-9]{6}$/) && (!data.exists() || data.val() === auth.uid)",
          ".validate": "newData.isString() && newData.val() === auth.uid && newData.val().length <= 128"
        },

        "displayOnline": {
          "//": "Only the room owner (the Display) may set/clear its presence flag.",
          ".write": "auth != null && root.child('rooms').child($code).child('owner').val() === auth.uid",
          ".validate": "newData.isBoolean()"
        },

        "controllerOnline": {
          ".write": "auth != null && $code.matches(/^[A-Z0-9]{6}$/)",
          ".validate": "newData.isBoolean()"
        },

        "command": {
          ".write": "auth != null && $code.matches(/^[A-Z0-9]{6}$/)",
          ".validate": "newData.hasChildren(['action', 'sentAt'])",
          "action":    { ".validate": "newData.isString() && newData.val().matches(/^(load|play|pause|seek)$/)" },
          "videoId":   { ".validate": "newData.isString() && newData.val().length <= 20 && newData.val().matches(/^[A-Za-z0-9_-]+$/)" },
          "title":     { ".validate": "newData.isString() && newData.val().length <= 200" },
          "timestamp": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 86400" },
          "sentAt":    { ".validate": "newData.isNumber()" },
          "$other":    { ".validate": false }
        },

        "$other": { ".validate": false }
      }
    }
  }
}
