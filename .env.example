# SyncWatch configuration — canonical values.
#
# NOTE: SyncWatch is a static browser app with no build step, so it does NOT
# read this file automatically. This is just a safe, git-ignored place to keep
# your real key values. After filling them in, copy them into
# syncwatch/firebase-config.js (which is git-ignored).
#
# Copy this file to ".env" and fill in real values:
#   cp .env.example .env

# ── Firebase (Console → Project Settings → Your apps → SDK config) ──
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_DATABASE_URL=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# ── YouTube Data API v3 (Google Cloud Console → Credentials) ──
# Remember to restrict this key by website + API. See firebase-config.js.
YOUTUBE_API_KEY=
